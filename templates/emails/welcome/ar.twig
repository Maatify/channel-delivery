{% extends "emails/layouts/base.twig" %}

{% block subject %}مرحباً بك في {{ app_name }}، {{ user_name }}!{% endblock %}

{% block body %}
<table width="100%" cellpadding="0" cellspacing="0"
       style="max-width:600px; margin:0 auto; direction:rtl; text-align:right;">

    {# Header #}
    <tr>
        <td style="background:#4F46E5; padding:32px; text-align:center; border-radius:8px 8px 0 0;">
            <h1 style="color:#ffffff; margin:0; font-size:24px; font-weight:bold;">
                أهلاً بك 👋
            </h1>
        </td>
    </tr>

    {# Body #}
    <tr>
        <td style="background:#ffffff; padding:32px;">
            <p style="font-size:16px; color:#333333; line-height:1.8; margin:0 0 16px;">
                مرحباً <strong>{{ user_name }}</strong>،
            </p>
            <p style="font-size:16px; color:#333333; line-height:1.8; margin:0 0 32px;">
                شكراً لتسجيلك. يرجى تفعيل حسابك بالنقر على الزر أدناه.
            </p>

            <div style="text-align:center; margin:0 0 32px;">
                <a href="{{ activation_link }}"
                   style="background:#4F46E5; color:#ffffff; padding:14px 32px;
                          border-radius:6px; font-size:16px; font-weight:bold;
                          display:inline-block;">
                    تفعيل الحساب
                </a>
            </div>

            <p style="font-size:13px; color:#888888; line-height:1.8; margin:0;">
                إذا لم يعمل الزر، انسخ الرابط التالي في متصفحك:<br>
                <a href="{{ activation_link }}" style="color:#4F46E5; word-break:break-all;">
                    {{ activation_link }}
                </a>
            </p>
        </td>
    </tr>

    {# Footer #}
    <tr>
        <td style="background:#f9f9f9; padding:16px 32px; text-align:center;
                   border-top:1px solid #eeeeee; border-radius:0 0 8px 8px;">
            <p style="font-size:12px; color:#aaaaaa; margin:0;">
                هل تحتاج مساعدة؟ تواصل معنا على
                <a href="mailto:{{ support_email }}" style="color:#4F46E5;">{{ support_email }}</a>
            </p>
        </td>
    </tr>

</table>
{% endblock %}

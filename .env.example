APP_ENV=development
APP_NAME="My App"
SUPPORT_EMAIL=support@example.com
# ── Database ──────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=channel_delivery
DB_USERNAME=root
DB_PASSWORD=secret

# ── Crypto Keys ───────────────────────────────────────────────
# Key value must be exactly 32 raw bytes.
# Generate: php -r "echo random_bytes(32);" > key.bin
# Then read it in your bootstrap or store as-is in CRYPTO_KEYS.
#
# To add a rotated key, append it to the array with a new id.
# Old keys stay INACTIVE (decryption only).
#
CRYPTO_ACTIVE_KEY_ID=v1
CRYPTO_KEYS='[{"id":"v1","key":"replace_with_32_byte_secret_here"}]'

# ── SMTP ──────────────────────────────────────────────────────
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your_mailtrap_user
MAIL_PASSWORD=your_mailtrap_pass
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Channel Delivery"
MAIL_ENCRYPTION=tls
MAIL_TIMEOUT=10
MAIL_DEBUG=0

# ── Redis ──────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
TRUSTED_PROXIES=

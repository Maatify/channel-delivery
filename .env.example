# ============================================================
# Application — REQUIRED
# ============================================================

# Application environment
# ⚠️ IMPORTANT:
# Default is development for local setup only.
# NEVER use this value in production.
# REQUIRED — must be explicitly set in each deployment environment.
# Allowed values:
#   - production
#   - staging
#   - development
APP_ENV=development

# Application display name
# Used in:
#   - email templates
#   - system metadata
#   - internal service identification
APP_NAME="My App"

# Support email address
# Used in:
#   - template globals
#   - support/contact references
#   - system-generated email content
SUPPORT_EMAIL=support@example.com

# ============================================================
# Database (MySQL) — REQUIRED
# ============================================================

# Database host
DB_HOST=127.0.0.1

# Database port
# Default MySQL port is 3306
DB_PORT=3306

# Database name
# MUST match the actual database created for the service
DB_DATABASE=channel_delivery

# Database username
DB_USERNAME=root

# Database password
# ⚠️ Secret — never commit real credentials
DB_PASSWORD=secret

# ============================================================
# Crypto — REQUIRED
# ============================================================

# Active encryption key id
# MUST match one of the ids declared inside CRYPTO_KEYS.
# Used for all new encryption operations.
CRYPTO_ACTIVE_KEY_ID=v1

# Encryption key registry
# Format: JSON array of key objects
# Example:
#   [{"id":"v1","key":"...32-byte-secret..."}]
#
# Key requirements:
# - each key must be exactly 32 raw bytes
# - key ids must be unique
# - old keys must remain available for decryption of previously stored data
#
# Rotation policy:
# - add the new key with a new id
# - switch CRYPTO_ACTIVE_KEY_ID to the new id
# - keep previous keys for decryption only
# - remove old keys only after legacy encrypted data is no longer needed
#
# Example generation:
#   php -r "echo random_bytes(32);" > key.bin
#
# ⚠️ Secret — never commit real encryption keys
CRYPTO_KEYS='[{"id":"v1","key":"replace_with_32_byte_secret_here"}]'

# ============================================================
# SMTP — REQUIRED
# ============================================================

# SMTP host
# Used by the email worker to deliver queued messages
MAIL_HOST=smtp.mailtrap.io

# SMTP port
# Common values:
#   - 587 for TLS
#   - 465 for SSL
MAIL_PORT=587

# SMTP username
MAIL_USERNAME=your_mailtrap_user

# SMTP password
# ⚠️ Secret — never commit real credentials
MAIL_PASSWORD=your_mailtrap_pass

# Default sender email address
# Used as the From address for outgoing emails
MAIL_FROM_ADDRESS=no-reply@example.com

# Default sender display name
MAIL_FROM_NAME="Channel Delivery"

# SMTP encryption mode
# Common values:
#   - tls
#   - ssl
# Leave empty only if your SMTP provider explicitly requires no encryption
MAIL_ENCRYPTION=tls

# SMTP timeout in seconds
MAIL_TIMEOUT=10

# SMTP debug level
# Recommended:
#   - 0 in production
#   - enable higher values only for local troubleshooting
MAIL_DEBUG=0

# ============================================================
# Redis / Rate Limiting — OPTIONAL / RECOMMENDED
# ============================================================

# Redis host
# Used for rate limiting and runtime coordination
REDIS_HOST=127.0.0.1

# Redis port
REDIS_PORT=6379

# Redis password
# Leave empty if Redis authentication is disabled
# ⚠️ Secret when used
REDIS_PASSWORD=

# Redis database index
REDIS_DB=0

# Maximum number of requests allowed within the configured rate-limit window
RATE_LIMIT_MAX_REQUESTS=100

# Rate-limit window duration in seconds
RATE_LIMIT_WINDOW_SECONDS=60

# Trusted reverse proxies
# Comma-separated IP addresses or CIDR ranges
# Leave empty when the service is not behind a reverse proxy
TRUSTED_PROXIES=

# ============================================================
# Logging — REQUIRED
# ============================================================

# Log output directory
# The application must have write permission to this path
LOG_PATH=./storage/logs

# Number of days to retain log files
# Older log files may be removed by cleanup or rotation routines
LOG_RETENTION_DAYS=14

# Timezone used for log timestamps and log rotation logic
# Must be a valid PHP timezone identifier
LOG_TIMEZONE=Africa/Cairo

{
  "name": "maatify/channel-delivery",
  "description": "Maatify Channel Delivery — Standalone async multi-channel delivery microservice (Email, Telegram, SMS, Push...)",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-openssl": "*",
    "ext-pdo": "*",
    "ext-redis": "*",
    "ext-sodium": "*",
    "ext-zlib": "*",
    "maatify/crypto": "^1.0",
    "maatify/psr-logger": "^1.0",
    "maatify/shared-common": "^1.0",
    "php-di/php-di": "^7.1",
    "php-di/slim-bridge": "^3.0",
    "phpmailer/phpmailer": "^6.9",
    "psr/http-message": "^2.0",
    "psr/http-server-handler": "^1.0",
    "psr/http-server-middleware": "^1.0",
    "psr/log": "^3.0",
    "slim/psr7": "^1.8",
    "slim/slim": "^4.15",
    "twig/twig": "^3.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Maatify\\ChannelDelivery\\": "src/",
      "Maatify\\EmailDelivery\\": "Modules/EmailDelivery/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse src Modules tests --level=max",
    "format": "php-cs-fixer fix"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "platform": {
      "php": "8.2.0"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
